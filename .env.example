# Optional shared token required by the broker for volunteer-class registration.
OPENRUNG_VOLUNTEER_TOKEN=change-me

# Optional shared relay-state backend for safer broker restarts and multiple
# brokers behind one load balancer. Leave as memory for local development.
OPENRUNG_RELAY_STORE=memory
# OPENRUNG_RELAY_STORE=postgres
# OPENRUNG_RELAY_DATABASE_URL=postgres://openrung:change-me@localhost:5432/openrung?sslmode=disable
OPENRUNG_RELAY_RANKING=global
