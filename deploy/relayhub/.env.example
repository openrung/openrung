# OpenRung relay hub configuration.
# Copy to .env and fill in. Only the two values under "Required" are mandatory.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------
# Public IP or DNS name clients use to reach relays served by THIS hub. This is
# advertised to clients as the relay's public_host. Use a public IP or a DNS
# name with A/AAAA records pointing at this host.
OPENRUNG_HUB_PUBLIC_HOST=hub.example.com

# Base URL of the broker the hub registers tunneled relays with.
OPENRUNG_BROKER_URL=https://broker.example.com

# ---------------------------------------------------------------------------
# Control channel + ports (optional)
# ---------------------------------------------------------------------------
# Address volunteers dial to establish a tunnel (default :9443).
#OPENRUNG_HUB_CONTROL_ADDR=:9443
# Public TCP port range allocated to tunneled relays, one port per volunteer.
#OPENRUNG_HUB_PORT_RANGE=20000-20100
# Interface the per-tunnel public listeners bind to (default all interfaces).
#OPENRUNG_HUB_PUBLIC_BIND_HOST=

# ---------------------------------------------------------------------------
# Auth (optional, strongly recommended)
# ---------------------------------------------------------------------------
# Shared bearer token: volunteers must present it to open a tunnel, and the hub
# uses it for its broker registration calls. Must match the broker's token.
#OPENRUNG_VOLUNTEER_TOKEN=

# ---------------------------------------------------------------------------
# TLS on the control channel (optional, strongly recommended)
# ---------------------------------------------------------------------------
# Without these the control channel runs in plaintext and the volunteer token is
# sent in the clear. Mount the cert/key into the container (see docker-compose).
#OPENRUNG_HUB_TLS_CERT=/etc/openrung/certs/hub.crt
#OPENRUNG_HUB_TLS_KEY=/etc/openrung/certs/hub.key

# ---------------------------------------------------------------------------
# Liveness (optional)
# ---------------------------------------------------------------------------
# How often the hub re-heartbeats each live relay to the broker. Keep it well
# under the broker's lease TTL (default 3m).
#OPENRUNG_HUB_HEARTBEAT_INTERVAL=30s

# ---------------------------------------------------------------------------
# Hub HTTP API (optional) — enables volunteer reachability auto-detection and,
# with reflectors, NAT hole punching. Set OPENRUNG_HUB_HTTP_ADDR to turn it on.
# Open its TCP port in the firewall and do NOT front it with a proxy (the
# volunteer's real source IP must be observable). See README.md.
# ---------------------------------------------------------------------------
#OPENRUNG_HUB_HTTP_ADDR=:9444
#
# NAT hole punching (optional): lets clients reach CGNAT volunteers directly,
# bypassing the hub data path. Enabled only when HTTP_ADDR is set AND reflectors
# are configured. Also open the reflector UDP port(s) in your firewall.
#
# REFLECTOR_ADDRS is the BIND list (addresses on the host NIC). On AWS the public
# IP is 1:1-NAT'd and NOT on the NIC, so bind the private IP or a wildcard and set
# REFLECTOR_ADVERTISE to the public IP(s) peers should probe (positionally matched).
# Two distinct public vantage points enable NAT classification; one degrades to
# "unknown" (attempt-then-fallback).
#
# Lightsail (single public IPv4) — degraded single-IP mode:
#OPENRUNG_HUB_REFLECTOR_ADDRS=:19302
#OPENRUNG_HUB_REFLECTOR_ADVERTISE=203.0.113.10:19302
#
# EC2 (two Elastic IPs on two secondary private IPs) — full classification:
#OPENRUNG_HUB_REFLECTOR_ADDRS=10.0.0.10:19302,10.0.0.11:19302
#OPENRUNG_HUB_REFLECTOR_ADVERTISE=203.0.113.10:19302,203.0.113.11:19302
#OPENRUNG_HUB_PUNCH_TTL=6s
