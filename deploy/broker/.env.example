# OpenRung broker configuration. Copy to .env and edit, then:
#   docker compose up -d --build
#
# The broker is configured entirely through OPENRUNG_* environment variables.

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------
# Shared bearer token volunteers/hubs must present to register a relay. It gates
# the relay directory that clients route their VPN traffic through.
#
# The broker refuses to start without a token, so this template opts into an
# open, unauthenticated broker (anyone can register a relay). This is a
# deliberate choice: OpenRung's public network intentionally runs open so any
# volunteer can contribute a relay without a shared secret. To require auth
# instead (e.g. a private deployment), set OPENRUNG_VOLUNTEER_TOKEN below — a
# token supersedes the anonymous flag, which then becomes a no-op — and remove
# or comment out the anonymous line.
#
# Keep this line HERE, in the env file loaded via --env-file, not as an ad-hoc
# `docker run -e OPENRUNG_ALLOW_ANONYMOUS_REGISTRATION=true`. The broker fails
# closed at startup, so a redeploy that forgets an inline -e flag crash-loops;
# in the env file the opt-in travels with every recreate.
OPENRUNG_ALLOW_ANONYMOUS_REGISTRATION=true
#OPENRUNG_VOLUNTEER_TOKEN=

# Privileged token that authorizes node_class=foundation registrations, so
# clients can tell foundation-operated relays from community volunteers in the
# signed relay list. Give it ONLY to relays the foundation runs itself — never
# to volunteers or community hubs — and generate it independently of the
# volunteer token (the broker refuses to start when the two are equal, since a
# shared value would let any volunteer self-label as foundation). Unset
# disables foundation registration; anonymous/volunteer registration is
# unaffected either way.
#   openssl rand -hex 32
# Keep the populated env file root-owned and mode 0600. On cloud hosts, transfer
# this value only after boot over an authenticated channel; never put it in
# cloud-init/user-data, provider metadata, inline docker -e arguments, or traced
# shell commands. Recreate the container with --env-file after changing it — a
# restart does not reload container environment variables.
#OPENRUNG_FOUNDATION_TOKEN=

# ---------------------------------------------------------------------------
# Relay-list signing (required)
# ---------------------------------------------------------------------------
# Standard base64 of the 32-byte Ed25519 seed that signs every relay-list
# response (detached signature in the X-OpenRung-Relays-Signature header), so
# clients can verify the directory over non-TLS channels. The broker refuses to
# start without it — serving unsigned lists would look healthy while every
# verifying client rejected discovery. Generate a seed with:
#   openssl rand -base64 32
# Clients pin the matching public keys, so production must use the operator's
# active seed. Keep this file 0600 once a real seed is in it; NEVER commit one.
#OPENRUNG_RELAY_SIGNING_KEY=

# ---------------------------------------------------------------------------
# Telemetry dashboard (optional)
# ---------------------------------------------------------------------------
# Set a long random token to enable the protected /admin/telemetry dashboard.
# When unset, the dashboard and its data API return 404. Serve the broker over
# HTTPS (e.g. behind Cloudflare) so the admin session cookie is protected.
#OPENRUNG_DASHBOARD_TOKEN=

# ---------------------------------------------------------------------------
# Listen address (optional)
# ---------------------------------------------------------------------------
# With host networking (the compose default) this binds directly on the host.
#OPENRUNG_ADDR=:8080

# ---------------------------------------------------------------------------
# Trusted proxies (optional)
# ---------------------------------------------------------------------------
# Cloudflare's published ranges are trusted by default for CF-Connecting-IP /
# X-Forwarded-For. Add extra CIDRs (e.g. an upstream load balancer) here,
# comma-separated. Do NOT add broad ranges — a too-wide entry lets clients spoof
# their source IP past rate limiting.
#OPENRUNG_TRUSTED_PROXY_CIDRS=

# ---------------------------------------------------------------------------
# Relay state store (optional; defaults to in-memory)
# ---------------------------------------------------------------------------
# memory (default) keeps relay state in the process; postgres shares it across
# restarts / multiple brokers behind a load balancer.
#OPENRUNG_RELAY_STORE=postgres
#OPENRUNG_RELAY_DATABASE_URL=postgres://openrung:change-me@db:5432/openrung?sslmode=disable

# Relay ranking: global (default, live-metric scoring) or legacy (IPv6-first).
#OPENRUNG_RELAY_RANKING=global

# ---------------------------------------------------------------------------
# Relay geolocation (optional)
# ---------------------------------------------------------------------------
# HTTP endpoint used to resolve a relay's public IP to city/country for the map.
# Set to "off" to disable outbound geo lookups entirely.
#OPENRUNG_GEOIP_ENDPOINT=off

# ---------------------------------------------------------------------------
# Telemetry storage (optional; defaults to the JSONL file)
# ---------------------------------------------------------------------------
# jsonl (default) appends events to OPENRUNG_TELEMETRY_FILE with zero
# dependencies; postgres writes them to a daily-partitioned telemetry_events
# table instead — recommended for production. The database URL falls back to
# OPENRUNG_RELAY_DATABASE_URL, so a broker already on the postgres relay store
# only needs the first line.
#OPENRUNG_TELEMETRY_STORE=postgres
#OPENRUNG_TELEMETRY_DATABASE_URL=postgres://openrung:change-me@db:5432/openrung?sslmode=disable

# The image points the JSONL file at the persistent named volume; override only
# if you change the volume mount in docker-compose.yml. Unused in postgres mode.
#OPENRUNG_TELEMETRY_FILE=/var/lib/openrung/telemetry.jsonl
