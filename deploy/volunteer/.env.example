# OpenRung volunteer relay configuration.
# Copy to .env and fill in. Only the two values under "Required" are mandatory.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------
# Base URL of the broker this relay registers with.
OPENRUNG_BROKER_URL=https://broker.example.com

# Public IP or DNS name clients use to reach THIS relay. A container cannot
# auto-detect the host's public address, so it must be set explicitly. Use the
# server's public IPv6 or IPv4 address, or a DNS name with A/AAAA records.
OPENRUNG_PUBLIC_HOST=2001:db8::1234

# ---------------------------------------------------------------------------
# CGNAT reverse-tunnel mode (optional)
# ---------------------------------------------------------------------------
# Set OPENRUNG_TUNNEL=true if THIS relay is behind CGNAT (no inbound port). The
# volunteer then dials a relay hub instead of exposing a public port: the hub
# allocates a public port and registers the relay with the broker on its behalf.
# In tunnel mode OPENRUNG_BROKER_URL and OPENRUNG_PUBLIC_HOST above are NOT used
# (only OPENRUNG_HUB_ADDR is required), and the container needs no inbound port
# and no NET_BIND_SERVICE — you can drop that capability and use bridge
# networking. Use direct mode whenever this host actually has a public IP/IPv6,
# since direct relays do not consume hub bandwidth.
#OPENRUNG_TUNNEL=true
# Relay hub control address (host:port).
#OPENRUNG_HUB_ADDR=hub.example.com:9443
# Dial the hub over TLS (default true). Set false only for a plaintext hub.
#OPENRUNG_HUB_TLS=true
# Skip hub TLS certificate verification (testing only, e.g. self-signed certs).
#OPENRUNG_HUB_INSECURE=false

# ---------------------------------------------------------------------------
# Networking (optional, direct mode only)
# ---------------------------------------------------------------------------
# Public port clients connect to (default 443).
#OPENRUNG_PUBLIC_PORT=443
# Local listen host inside the container (default ::; use 0.0.0.0 for IPv4-only).
#OPENRUNG_LISTEN_HOST=::
# Local listen port (default 443).
#OPENRUNG_LISTEN_PORT=443

# ---------------------------------------------------------------------------
# Broker auth (required against a production broker)
# ---------------------------------------------------------------------------
# Registration token the broker requires. Production brokers require one by
# default (they refuse to start open), so set this to match the broker's token.
#OPENRUNG_VOLUNTEER_TOKEN=

# ---------------------------------------------------------------------------
# Stable relay identity (optional, recommended)
# ---------------------------------------------------------------------------
# Generate a key pair once with:
#   docker run --rm --entrypoint xray openrung-volunteer:latest x25519
# Without these four, a fresh identity is generated on every restart.
#OPENRUNG_CLIENT_ID=
#OPENRUNG_REALITY_PRIVATE_KEY=
#OPENRUNG_REALITY_PUBLIC_KEY=
#OPENRUNG_SHORT_ID=

# ---------------------------------------------------------------------------
# Reality camouflage (optional)
# ---------------------------------------------------------------------------
#OPENRUNG_SERVER_NAME=www.cloudflare.com
#OPENRUNG_REALITY_DEST=www.cloudflare.com:443

# ---------------------------------------------------------------------------
# Advertised capacity (optional)
# ---------------------------------------------------------------------------
#OPENRUNG_MAX_SESSIONS=8
#OPENRUNG_MAX_MBPS=20
#OPENRUNG_HEARTBEAT_INTERVAL=30s

# ---------------------------------------------------------------------------
# Misc (optional)
# ---------------------------------------------------------------------------
# Set false to let xray bind the public port directly (disables the connection log).
#OPENRUNG_CONNECTION_LOG=true
# Where the generated xray config is written inside the container.
#OPENRUNG_CONFIG_OUT=/tmp/openrung-xray-config.json
# Path to the xray binary inside the image.
#OPENRUNG_XRAY_PATH=/usr/local/bin/xray
