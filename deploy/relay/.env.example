# OpenRung relay runtime configuration.
# Copy to .env and fill in. Only the two values under "Required" are mandatory.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------
# Base URL of the broker this relay registers with.
OPENRUNG_BROKER_URL=https://broker.example.com

# Public IP or DNS name clients use to reach THIS relay. A container cannot
# auto-detect the host's public address, so it must be set explicitly. Use the
# server's public IPv6 or IPv4 address, or a DNS name with A/AAAA records.
OPENRUNG_PUBLIC_HOST=2001:db8::1234

# ---------------------------------------------------------------------------
# CGNAT reverse-tunnel mode (optional)
# ---------------------------------------------------------------------------
# Set OPENRUNG_MODE=tunnel if THIS relay is behind CGNAT (no inbound port). The
# relay then dials a relay hub instead of exposing a public port: the hub
# allocates a public port and registers the relay with the broker on its behalf.
# In tunnel mode OPENRUNG_BROKER_URL and OPENRUNG_PUBLIC_HOST above are NOT used
# (only OPENRUNG_HUB_ADDR is required), and the container needs no inbound port
# and no NET_BIND_SERVICE — you can drop that capability and use bridge
# networking. Use direct mode whenever this host actually has a public IP/IPv6,
# since direct relays do not consume hub bandwidth.
# Connection mode: direct, tunnel, or auto. When unset, configuring a hub
# selects auto; without a hub it defaults to direct. Foundation deployments
# should set this to direct explicitly so adding a hub cannot select rejected
# auto mode.
#OPENRUNG_MODE=direct
# Legacy compatibility only; ignored when OPENRUNG_MODE is set.
#OPENRUNG_TUNNEL=true
# Relay hub control address (host:port).
#OPENRUNG_HUB_ADDR=hub.example.com:9443
# Dial the hub over TLS (default true). Set false only for a plaintext hub.
#OPENRUNG_HUB_TLS=true
# Skip hub TLS certificate verification (testing only, e.g. self-signed certs).
#OPENRUNG_HUB_INSECURE=false

# ---------------------------------------------------------------------------
# Networking (optional, direct mode only)
# ---------------------------------------------------------------------------
# Public port clients connect to (default 443).
#OPENRUNG_PUBLIC_PORT=443
# Local listen host inside the container (default ::; use 0.0.0.0 for IPv4-only).
#OPENRUNG_LISTEN_HOST=::
# Local listen port (default 443).
#OPENRUNG_LISTEN_PORT=443

# ---------------------------------------------------------------------------
# Broker auth (required against a production broker)
# ---------------------------------------------------------------------------
# Registration token the broker requires. Production brokers require one by
# default (they refuse to start open), so set this to match the broker's token.
#OPENRUNG_VOLUNTEER_TOKEN=

# Foundation relays (run by the OpenRung Foundation itself) present the broker's
# foundation token here. It is a self-contained posture: setting it alone runs
# the relay as node_class=foundation, forces direct mode, and requires an https
# OPENRUNG_BROKER_URL with broker redirects refused (so the token cannot enter a
# hub path or follow an HTTPS-to-HTTP downgrade). You do NOT also set
# OPENRUNG_NODE_CLASS or OPENRUNG_MODE — the token forces both. The value is the
# same secret configured as OPENRUNG_FOUNDATION_TOKEN on the broker. A
# Foundation-operated hub still registers community exits tunneled through it as
# `node_class=volunteer`.
#
# Keep the populated env file root-owned and mode 0600. Transfer the token only
# after boot over an authenticated channel; never place it in cloud-init/
# user-data, provider metadata, inline docker -e arguments, or traced shell
# commands. Recreate the container with --env-file after changing it.
#OPENRUNG_FOUNDATION_TOKEN=

# Operator class, for the rare case of setting it without the foundation token:
# volunteer (default) or foundation. Leave unset when OPENRUNG_FOUNDATION_TOKEN
# is set (the token already forces foundation); setting it to anything but
# foundation alongside the token is a startup error.
#OPENRUNG_NODE_CLASS=volunteer

# ---------------------------------------------------------------------------
# Stable relay identity (optional for ordinary relays; required for WSS)
# ---------------------------------------------------------------------------
# Generate Reality keys once with:
#   docker run --rm --entrypoint xray openrung-relay:latest x25519
# Generate the independent, stable relay-identity seed once with:
#   openssl rand -base64 32
# Store it as one line. Without OPENRUNG_IDENTITY_SEED the relay identity and ID
# change after every process restart, so WSS advertisement is refused.
#OPENRUNG_IDENTITY_SEED=
#OPENRUNG_CLIENT_ID=
#OPENRUNG_REALITY_PRIVATE_KEY=
#OPENRUNG_REALITY_PUBLIC_KEY=
#OPENRUNG_SHORT_ID=

# ---------------------------------------------------------------------------
# Per-relay WSS/CDN fallback (optional, Foundation direct relays only)
# ---------------------------------------------------------------------------
# Comma-separated front-id=URL entries. Each CDN distribution must use THIS
# relay as its origin; the broker signs and advertises these exact per-relay
# entries and never supplies a shared gateway. URLs use only the fixed sidecar
# path and never contain tickets, tokens, queries, or destination addresses.
# Requires Foundation class, direct mode, public/listen port 443, the explicit
# stable OPENRUNG_IDENTITY_SEED above, and the privacy posture below. Xray must
# bind the IPv4 wildcard directly so the fixed sidecar target reaches
# 127.0.0.1:443 without the per-connection observer creating stream records.
#OPENRUNG_LISTEN_HOST=0.0.0.0
#OPENRUNG_CONNECTION_LOG=false
#OPENRUNG_WSS_FRONTS=iran-a=wss://d111111abcdef8.cloudfront.net/api/v1/wss-bridge,iran-b=wss://wss-b.example.org/api/v1/wss-bridge
#
# The sidecar is in this same image/compose file but disabled by default. Copy
# .wss.env.example to root-only .wss.env, configure it, then enable it with:
#   docker compose --profile wss up -d --build
# Keep sidecar origin tokens in .wss.env, never in this relay env file.

# ---------------------------------------------------------------------------
# Reality camouflage (optional)
# ---------------------------------------------------------------------------
#OPENRUNG_SERVER_NAME=www.cloudflare.com
#OPENRUNG_REALITY_DEST=www.cloudflare.com:443

# ---------------------------------------------------------------------------
# Advertised capacity (optional)
# ---------------------------------------------------------------------------
#OPENRUNG_MAX_SESSIONS=75
#OPENRUNG_MAX_MBPS=100
#OPENRUNG_HEARTBEAT_INTERVAL=30s

# ---------------------------------------------------------------------------
# Misc (optional)
# ---------------------------------------------------------------------------
# Set false to let xray bind the public port directly. This is required when
# OPENRUNG_WSS_FRONTS is set so WSS streams create no per-connection records.
#OPENRUNG_CONNECTION_LOG=true
# Where the generated xray config is written inside the container.
#OPENRUNG_CONFIG_OUT=/tmp/openrung-xray-config.json
# Path to the xray binary inside the image.
#OPENRUNG_XRAY_PATH=/usr/local/bin/xray
