# OpenRung relay-local WSS sidecar configuration.
#
# Copy to .wss.env on one eligible Foundation relay, set mode 0600, and keep it
# on that host. This file is consumed only by the colocated wss-sidecar service;
# it must not be shared between relays or used to run a gateway fleet.

# Exact stable relay ID derived by the broker from this relay's
# OPENRUNG_IDENTITY_SEED. It appears in the relay's successful registration log.
OPENRUNG_WSS_RELAY_ID=relay_replace_with_this_relays_id

# Comma-separated standard-base64 Ed25519 broker ticket public keys. Install the
# new public key alongside the old key before rotating the broker signer; remove
# the old key only after every issued ticket and allowed clock skew have elapsed.
OPENRUNG_WSS_TICKET_PUBLIC_KEYS=replace_with_current_public_key,replace_with_previous_public_key_during_overlap

# JSON object mapping each exact OPENRUNG_WSS_FRONTS ID to that CDN
# distribution's origin token set. The first token is current; retain the prior
# token during rotation overlap. A token must be unique to one front and contain
# 32..512 non-whitespace bytes. Configure the matching token as a CloudFront
# custom origin header; never put it in the advertised URL.
OPENRUNG_WSS_FRONT_ORIGIN_TOKENS={"iran-a":["replace-with-at-least-32-random-bytes-current","replace-with-at-least-32-random-bytes-previous"],"iran-b":["replace-with-a-different-32-byte-token"]}

# Loopback listener behind host-managed origin TLS on port 8443. Do not expose
# this listener publicly. The only upstream is the sidecar's built-in
# 127.0.0.1:443 Reality target; do not override OPENRUNG_WSS_FIXED_TARGET in
# production.
#OPENRUNG_WSS_ADDR=127.0.0.1:8081

# Durable, fail-closed single-use ticket journal. The compose service mounts a
# relay-local named volume at /var/lib/openrung so replay protection survives
# sidecar and container restarts. Do not place this on tmpfs, delete it during a
# routine rollout, or share it with another relay.
#OPENRUNG_WSS_REPLAY_STATE=/var/lib/openrung/wss-replay.journal

# Iranian carrier-grade NAT can place many legitimate clients behind one
# source address. Tune these bounded per-source controls only from measurements.
#OPENRUNG_WSS_MAX_SESSIONS_PER_SOURCE=512
#OPENRUNG_WSS_MAX_STREAMS_PER_SOURCE=4096
#OPENRUNG_WSS_HANDSHAKE_RATE=10
#OPENRUNG_WSS_HANDSHAKE_BURST=100

# Independent aggregate handshake bounds protect the relay even when source
# attribution is unavailable or spread across many addresses.
#OPENRUNG_WSS_MAX_PENDING_HANDSHAKES=4096
#OPENRUNG_WSS_GLOBAL_HANDSHAKE_RATE=2000
#OPENRUNG_WSS_GLOBAL_HANDSHAKE_BURST=10000

# Bounded lifecycle controls (safe defaults are used when omitted).
#OPENRUNG_WSS_HANDSHAKE_TIMEOUT=10s
#OPENRUNG_WSS_DIAL_TIMEOUT=5s
#OPENRUNG_WSS_FIRST_BYTE_TIMEOUT=10s
#OPENRUNG_WSS_STREAM_IDLE_TIMEOUT=5m
#OPENRUNG_WSS_SESSION_LIFETIME=6h
#OPENRUNG_WSS_NO_STREAM_IDLE_TIMEOUT=2m
