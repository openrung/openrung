# Keep the Docker build context small and free of non-Go assets / secrets.
# The relay image only needs go.mod/go.sum, cmd/, internal/, and
# deploy/relay/entrypoint.sh.

.git
.gitignore
.github
.DS_Store
**/.DS_Store

# Docs are not needed to build the relay.
*.md
# ...but the third-party notices must ship inside the image (license compliance).
!THIRD_PARTY_NOTICES.md
docs

# The desktop apps are separate Go modules the server images never build;
# keep them (and any locally installed frontend deps) out of the context.
desktop
desktop-volunteer
**/node_modules

# Build outputs / caches.
bin
dist
build
.build
.gocache
.cache
.claude

# Local runtime files and secrets.
.env
*.local.json
openrung-telemetry.jsonl
openrung-xray-config.json
